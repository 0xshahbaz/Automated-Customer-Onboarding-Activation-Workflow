    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  u.id,\n  u.email,\n  u.plan_tier,\n  u.signup_at,\n  MAX(CASE WHEN e.event_type = 'email_verified' THEN e.occurred_at END) AS verified_at,\n  MAX(CASE WHEN e.event_type = 'first_project_created' THEN e.occurred_at END) AS project_created_at,\n  MAX(CASE WHEN e.event_type = 'teammate_invited' THEN e.occurred_at END) AS invited_at,\n  MAX(CASE WHEN e.event_type = 'first_task_completed' THEN e.occurred_at END) AS activated_at\nFROM users u\nLEFT JOIN activation_events e ON u.id = e.user_id\nGROUP BY u.id, u.email, u.plan_tier, u.signup_at;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        208,
        656
      ],
      "id": "da5a4f83-9c5f-4a16-bd9f-1c8573f4b22c",
      "name": "Execute a SQL query",
      "credentials": {
