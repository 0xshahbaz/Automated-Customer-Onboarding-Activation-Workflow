    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  const d = item.json;\n  const now = new Date();\n\n  // Figure out current stage: the most recent milestone they've hit\n  let stage = 'signed_up';\n  let lastMilestoneAt = new Date(d.signup_at);\n\n  if (d.verified_at) {\n    stage = 'email_verified';\n    lastMilestoneAt = new Date(d.verified_at);\n  }\n  if (d.project_created_at) {\n    stage = 'first_project_created';\n    lastMilestoneAt = new Date(d.project_created_at);\n  }\n  if (d.invited_at) {\n    stage = 'teammate_invited';\n    lastMilestoneAt = new Date(d.invited_at);\n  }\n  if (d.activated_at) {\n    stage = 'activated';\n    lastMilestoneAt = new Date(d.activated_at);\n  }\n\n  // FROM (testing):\nconst minutesStalled = Math.floor((now - lastMilestoneAt) / (1000 * 60));\nconst STALL_THRESHOLD_MINUTES = 3;\nconst isStalled = stage !== 'activated' && minutesStalled >= STALL_THRESHOLD_MINUTES;\n\n// TO (real):\nconst daysStalled = Math.floor((now - lastMilestoneAt) / (1000 * 60 * 60 * 24));\nconst STALL_THRESHOLD_DAYS = 3;\nconst isStalled = stage !== 'activated' && daysStalled >= STALL_THRESHOLD_DAYS;\n\n  results.push({\n    json: {\n      ...d,\n      stage,\n      daysStalled,\n      isStalled\n    }\n  });\n}\n\nreturn results;"
      },
