    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH funnel AS (\n  SELECT\n    COUNT(*) AS total_signups,\n    COUNT(DISTINCT CASE WHEN e.event_type = 'email_verified' THEN u.id END) AS verified,\n    COUNT(DISTINCT CASE WHEN e.event_type = 'first_project_created' THEN u.id END) AS project_created,\n    COUNT(DISTINCT CASE WHEN e.event_type = 'teammate_invited' THEN u.id END) AS invited,\n    COUNT(DISTINCT CASE WHEN e.event_type = 'first_task_completed' THEN u.id END) AS activated\n  FROM users u\n  LEFT JOIN activation_events e ON u.id = e.user_id\n)\nSELECT\n  total_signups,\n  verified,\n  ROUND(100.0 * verified / NULLIF(total_signups, 0), 1) AS pct_verified,\n  project_created,\n  ROUND(100.0 * project_created / NULLIF(total_signups, 0), 1) AS pct_project_created,\n  invited,\n  ROUND(100.0 * invited / NULLIF(total_signups, 0), 1) AS pct_invited,\n  activated,\n  ROUND(100.0 * activated / NULLIF(total_signups, 0), 1) AS pct_activated\nFROM funnel;",
        "options": {}
      },
